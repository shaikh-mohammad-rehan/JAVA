// increment and decrement for char
class Rehan {
    public static void main(String[] args) {
        char B = 'c';
        char F = 'y';
        System.out.println(B++);
        System.out.println(B);
        System.out.println();
        System.out.println(++F);
        System.out.println(F);
    }
}

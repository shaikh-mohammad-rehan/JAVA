// #2: encryption and decryption

class encryption_and_decryption {
    public static void main(String[] args) {
        char y = 'B';
        
        y = (char)(y+2);        //Encryption
        System.out.println(y);
        
        y = (char)(y-2);        //Decryption
        System.out.println(y);
    }
}
